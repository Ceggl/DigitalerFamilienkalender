---
// Full-screen kiosk layout for wall display
// Optimized for large touch screen, constant visibility

import '@/styles/base.css';

interface Props {
  title?: string;
  showHeader?: boolean;
}

const { title = 'Familienkalender', showHeader = true } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>{title}</title>
  </head>
  <body class="flex flex-col h-screen bg-gradient-to-br from-blue-50 to-indigo-50">
    {
      showHeader && (
        <header class="bg-white shadow-md px-6 py-4 border-b border-gray-200">
          <h1 class="text-3xl font-bold text-gray-900">{title}</h1>
        </header>
      )
    }

    <main class="flex-1 overflow-auto p-6">
      <slot />
    </main>

    <!-- Safe area for kiosk bottom (in case there are navigation bars) -->
    <div class="h-2"></div>
  </body>
</html>

<style is:global>
  html,
  body {
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    overflow: hidden;
  }
</style>
