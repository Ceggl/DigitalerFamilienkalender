---
// Coin balance display with visual glass jar metaphor

interface Props {
  balance: number;
  targetCoins?: number;
  personName?: string;
  className?: string;
}

const { balance, targetCoins = 50, personName = 'Du', className = '' } = Astro.props;
const percentage = Math.min((balance / targetCoins) * 100, 100);
---

<div class={`w-full max-w-sm mx-auto ${className}`}>
  <div class="bg-white rounded-2xl border-2 border-yellow-200 shadow-lg p-6">
    <div class="text-center mb-6">
      <h3 class="text-lg font-semibold text-gray-900">{personName}s Münzen</h3>
    </div>

    <!-- Coin jar visualization -->
    <div class="flex items-end justify-center gap-4 mb-6">
      <div class="relative w-20 h-32 bg-gradient-to-b from-amber-50 to-amber-100 rounded-b-2xl border-4 border-amber-800">
        <!-- Jar fill -->
        <div
          class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-yellow-400 to-yellow-300 rounded-b-xl transition-all duration-500"
          style={`height: ${percentage}%`}
        ></div>
      </div>

      <!-- Coin emoji -->
      <div class="text-6xl animate-bounce">🪙</div>
    </div>

    <!-- Stats -->
    <div class="text-center space-y-2">
      <div class="text-4xl font-bold text-yellow-600">{balance}</div>
      <div class="text-gray-600 text-sm">
        {targetCoins - balance} Münzen bis zum Ziel
      </div>
      <div class="w-full bg-gray-200 rounded-full h-3 mt-4 overflow-hidden">
        <div
          class="bg-gradient-to-r from-yellow-400 to-yellow-600 h-full rounded-full transition-all duration-500"
          style={`width: ${percentage}%`}
        ></div>
      </div>
    </div>
  </div>
</div>
