---
// Form to create a new calendar event
// Uses basic HTML form submission (progressive enhancement)

interface Props {
  personId?: string; // Optional: if logged in
  defaultDate?: string; // ISO date
}

const { personId = '', defaultDate = new Date().toISOString().split('T')[0] } = Astro.props;
---

<form method="POST" action="/api/events" class="space-y-4">
  <div>
    <label for="title" class="block text-sm font-semibold text-gray-700 mb-2">
      Titel
    </label>
    <input
      id="title"
      name="title"
      type="text"
      required
      placeholder="z.B. Zahnarzttermin"
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 text-base"
    />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="startsAt" class="block text-sm font-semibold text-gray-700 mb-2">
        Startdatum
      </label>
      <input
        id="startsAt"
        name="startsAt"
        type="datetime-local"
        required
        value={defaultDate + 'T09:00'}
        class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 text-base"
      />
    </div>
    <div>
      <label for="endsAt" class="block text-sm font-semibold text-gray-700 mb-2">
        Enddatum
      </label>
      <input
        id="endsAt"
        name="endsAt"
        type="datetime-local"
        required
        value={defaultDate + 'T10:00'}
        class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 text-base"
      />
    </div>
  </div>

  <div>
    <label for="icon" class="block text-sm font-semibold text-gray-700 mb-2">
      Symbol (optional)
    </label>
    <input
      id="icon"
      name="icon"
      type="text"
      placeholder="z.B. 🦷"
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 text-base"
    />
  </div>

  <div>
    <label for="location" class="block text-sm font-semibold text-gray-700 mb-2">
      Ort (optional)
    </label>
    <input
      id="location"
      name="location"
      type="text"
      placeholder="z.B. Zahnarzt Dr. Müller"
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 text-base"
    />
  </div>

  <div class="flex items-center gap-3">
    <input
      id="allDay"
      name="allDay"
      type="checkbox"
      class="w-5 h-5 rounded border-gray-300"
    />
    <label for="allDay" class="text-sm font-medium text-gray-700">
      Ganztägiger Termin
    </label>
  </div>

  <input type="hidden" name="createdBy" value={personId} />

  <div class="flex gap-4">
    <button
      type="submit"
      class="flex-1 px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 active:scale-95 transition-all"
    >
      ➕ Termin erstellen
    </button>
    <button
      type="reset"
      class="flex-1 px-6 py-3 bg-gray-200 text-gray-900 font-semibold rounded-lg hover:bg-gray-300 active:scale-95 transition-all"
    >
      Zurücksetzen
    </button>
  </div>
</form>
