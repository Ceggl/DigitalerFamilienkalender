---
// Avatar grid for selecting/logging in a person
// Touch-optimized: large tiles, color-coded per person

interface Props {
  people: Array<{
    id: string;
    displayName: string;
    avatarKind: 'photo' | 'emoji' | 'illustration';
    avatarValue: string;
    color: string;
    role: 'adult' | 'caregiver' | 'child';
  }>;
  onSelect?: string; // client-side handler (hx or fetch)
}

import Avatar from '@/components/ui/Avatar.astro';

const { people, onSelect } = Astro.props;
---

<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
  {
    people.map((p) => (
      <button
        class="flex flex-col items-center gap-4 p-6 rounded-2xl bg-white border-2 border-gray-100 hover:border-blue-400 hover:shadow-lg transition-all duration-200 active:scale-95 min-h-56"
        onclick={`window.location.href = '/login?personId=${p.id}'`}
        title={p.displayName}
      >
        <Avatar
          kind={p.avatarKind}
          value={p.avatarValue}
          name={p.displayName}
          color={p.color}
          size="lg"
        />
        <span class="text-center text-sm font-semibold text-gray-900 line-clamp-2">
          {p.displayName}
        </span>
      </button>
    ))
  }
</div>
