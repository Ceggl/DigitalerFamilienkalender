---
// Month view calendar with event indicators
// Shows a full month with clickable days

interface Props {
  year: number;
  month: number; // 0-11
  events?: Array<{
    id: string;
    title: string;
    startsAt: string;
    color?: string;
    icon?: string;
  }>;
}

const { year, month, events = [] } = Astro.props;

// Get first day of month and number of days
const firstDay = new Date(year, month, 1);
const lastDay = new Date(year, month + 1, 0);
const daysInMonth = lastDay.getDate();
const startingDayOfWeek = firstDay.getDay(); // 0 = Sunday

// Get events by date for quick lookup
const eventsByDate = new Map<string, typeof events>();
events.forEach((event) => {
  const date = event.startsAt.split('T')[0]; // YYYY-MM-DD
  if (!eventsByDate.has(date)) {
    eventsByDate.set(date, []);
  }
  eventsByDate.get(date)!.push(event);
});

// Generate calendar grid
const days: Array<{ day: number | null; date: string }> = [];

// Empty slots before month starts
for (let i = 0; i < startingDayOfWeek; i++) {
  days.push({ day: null, date: '' });
}

// Days of the month
for (let day = 1; day <= daysInMonth; day++) {
  const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
  days.push({ day, date: dateStr });
}

const dayNames = ['So', 'Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa'];
---

<div class="space-y-4">
  <div class="grid grid-cols-7 gap-2">
    {dayNames.map((name) => <div class="text-center font-semibold text-gray-600 py-2">{name}</div>)}

    {
      days.map(({ day, date }) => {
        const dayEvents = eventsByDate.get(date) || [];
        const isToday =
          new Date().toISOString().split('T')[0] === date;

        return (
          <a
            href={day ? `/day/${date}` : '#'}
            class={`aspect-square p-2 rounded-lg border-2 transition-all duration-200
              ${!day ? 'bg-gray-50 border-transparent' : ''}
              ${day && !isToday ? 'bg-white border-gray-100 hover:border-blue-300 hover:shadow-md' : ''}
              ${day && isToday ? 'bg-blue-100 border-blue-500 shadow-md' : ''}
              ${!day ? 'pointer-events-none' : 'cursor-pointer'}
            `}
          >
            {day && (
              <div class="flex flex-col gap-1 h-full">
                <div class="text-sm font-semibold text-gray-900">{day}</div>
                <div class="flex-1 flex flex-col gap-0.5 overflow-hidden">
                  {dayEvents.slice(0, 2).map((evt) => (
                    <div
                      class={`text-xs px-1 py-0.5 rounded truncate font-medium ${
                        evt.color || 'bg-blue-100 text-blue-800'
                      }`}
                    >
                      {evt.icon && <span>{evt.icon} </span>}
                      <span class="truncate">{evt.title}</span>
                    </div>
                  ))}
                  {dayEvents.length > 2 && (
                    <div class="text-xs text-gray-500 px-1">+{dayEvents.length - 2} mehr</div>
                  )}
                </div>
              </div>
            )}
          </a>
        );
      })
    }
  </div>
</div>
