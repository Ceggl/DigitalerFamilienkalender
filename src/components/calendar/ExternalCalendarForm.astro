---
// Form to add external calendar (CalDAV)

interface Props {
  onSuccess?: string; // redirect URL
}

const { onSuccess = '/settings' } = Astro.props;
---

<form id="add-calendar-form" method="POST" action="/api/external-calendars" class="space-y-4">
  <div>
    <label for="label" class="block text-sm font-semibold text-gray-700 mb-2">
      Kalender-Name
    </label>
    <input
      id="label"
      name="label"
      type="text"
      required
      placeholder="z.B. Schulkalender"
      class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200"
    />
  </div>

  <div>
    <label for="provider" class="block text-sm font-semibold text-gray-700 mb-2">
      Anbieter
    </label>
    <select
      id="provider"
      name="provider"
      required
      class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:border-blue-500"
    >
      <option value="">-- Wähle einen Anbieter --</option>
      <option value="google">Google Kalender</option>
      <option value="icloud">iCloud (Apple)</option>
      <option value="nextcloud">Nextcloud</option>
      <option value="generic">Sonstiges (CalDAV)</option>
    </select>
  </div>

  <div>
    <label for="caldavUrl" class="block text-sm font-semibold text-gray-700 mb-2">
      CalDAV-URL
    </label>
    <input
      id="caldavUrl"
      name="caldavUrl"
      type="url"
      required
      placeholder="z.B. https://caldav.google.com/..."
      class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:border-blue-500"
    />
  </div>

  <div>
    <label for="username" class="block text-sm font-semibold text-gray-700 mb-2">
      Benutzername / E-Mail
    </label>
    <input
      id="username"
      name="username"
      type="text"
      required
      placeholder="z.B. max@example.com"
      class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:border-blue-500"
    />
  </div>

  <div>
    <label for="password" class="block text-sm font-semibold text-gray-700 mb-2">
      Passwort / App-Passwort
    </label>
    <input
      id="password"
      name="password"
      type="password"
      required
      placeholder="••••••••"
      class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:border-blue-500"
    />
    <p class="text-xs text-gray-500 mt-1">
      💡 Für Google/iCloud: Nutze ein Einmal-Passwort oder App-Passwort (nicht dein Haupt-Passwort!)
    </p>
  </div>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 text-sm text-blue-900">
    <p class="font-semibold mb-2">🔒 Sicherheit</p>
    <ul class="list-disc list-inside space-y-1 text-xs">
      <li>Passwörter werden verschlüsselt gespeichert</li>
      <li>Nur lokal auf diesem Gerät</li>
      <li>Nie an externe Server gesendet</li>
    </ul>
  </div>

  <div class="flex gap-3">
    <button
      type="submit"
      class="flex-1 px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 active:scale-95 transition-all"
    >
      ✅ Kalender verbinden
    </button>
    <button
      type="reset"
      class="flex-1 px-6 py-3 bg-gray-200 text-gray-900 font-semibold rounded-lg hover:bg-gray-300 transition-all"
    >
      🔄 Zurücksetzen
    </button>
  </div>
</form>

<script define:vars={{ onSuccess }}>
  document.getElementById('add-calendar-form').addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(e.target);
    const data = {
      label: formData.get('label'),
      provider: formData.get('provider'),
      caldavUrl: formData.get('caldavUrl'),
      username: formData.get('username'),
      password: formData.get('password'),
    };

    try {
      const response = await fetch('/api/external-calendars', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        alert('✅ Kalender verbunden! Termine werden in Kürze synchronisiert.');
        window.location.href = onSuccess;
      } else {
        const error = await response.json();
        alert(`Fehler: ${error.error}`);
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Verbindungsfehler. Bitte später erneut versuchen.');
    }
  });
</script>
