---
// My tasks page – personalized view of today's tasks and coins

import KioskLayout from '@/layouts/KioskLayout.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import TaskGrid from '@/components/tasks/TaskGrid.astro';
import CoinDisplay from '@/components/tasks/CoinDisplay.astro';
import RewardShop from '@/components/tasks/RewardShop.astro';
import { getTasksByHousehold } from '@/lib/services/task';
import { getRewardsByHousehold } from '@/lib/services/reward';
import { getCoinBalance } from '@/lib/services/coins';
import { getOrCreateDefaultHousehold } from '@/lib/services/household';

const personId = new URL(Astro.request.url).searchParams.get('personId') || '';

if (!personId) {
  return Astro.redirect('/login');
}

const household = await getOrCreateDefaultHousehold();
const tasks = household ? getTasksByHousehold(household.id) : [];
const rewards = household ? getRewardsByHousehold(household.id) : [];
const coinBalance = getCoinBalance(personId);

const today = new Date().toISOString().split('T')[0];
const dateDisplay = new Date().toLocaleDateString('de-DE', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
});

// Mock tasks for today (Phase 2 placeholder)
const todaysTasks = tasks.slice(0, 3).map((t) => ({
  id: t.id,
  title: t.title,
  icon: t.icon,
  coins: t.coins,
  requiresCommitment: !!t.requiresCommitment,
  status: 'open' as const,
}));
---

<KioskLayout title="Meine Aufgaben">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <Card className="mb-6">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Heute</h1>
          <p class="text-gray-600 mt-1 capitalize">{dateDisplay}</p>
        </div>
        <Button variant="ghost" size="md" onclick="window.location.href='/login'">
          👤 Wechseln
        </Button>
      </div>
    </Card>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Main tasks area -->
      <div class="lg:col-span-2 space-y-6">
        <Card>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">📋 Deine Aufgaben</h2>
          <TaskGrid tasks={todaysTasks} personId={personId} date={today} />
        </Card>
      </div>

      <!-- Sidebar: coins + rewards -->
      <div class="space-y-6">
        <Card>
          <CoinDisplay balance={coinBalance} personName="Deine" />
        </Card>

        <Card>
          <h3 class="text-lg font-semibold text-gray-900 mb-4">🎁 Belohnungen</h3>
          <div class="space-y-3">
            {
              rewards.slice(0, 3).map((r) => (
                <button
                  class="w-full p-3 rounded-lg bg-amber-50 border-2 border-amber-200 hover:border-amber-400 transition-all text-center"
                  onclick={`window.location.href='/rewards'`}
                >
                  <div class="text-2xl">{r.icon}</div>
                  <p class="text-xs font-semibold mt-1 text-gray-900">{r.title}</p>
                  <p class="text-xs text-yellow-600">🪙 {r.costCoins}</p>
                </button>
              ))
            }
          </div>
          <Button variant="secondary" size="md" className="w-full mt-3" onclick="window.location.href='/rewards'">
            Alle ansehen →
          </Button>
        </Card>
      </div>
    </div>
  </div>
</KioskLayout>
