---
// Login page – avatar selection
// When a person is selected, session is started

import KioskLayout from '@/layouts/KioskLayout.astro';
import Card from '@/components/ui/Card.astro';
import PersonGrid from '@/components/calendar/PersonGrid.astro';
import { getOrCreateDefaultHousehold } from '@/lib/services/household';
import { getPersonsByHousehold } from '@/lib/services/person';

const household = await getOrCreateDefaultHousehold();
let people = [];

if (household) {
  people = getPersonsByHousehold(household.id);
}
---

<KioskLayout title="Wer bist du?">
  <div class="max-w-6xl mx-auto">
    <Card className="mb-8 text-center">
      <h2 class="text-2xl font-bold text-gray-900">
        {people.length === 0
          ? '👥 Noch keine Personen hinzugefügt'
          : '👥 Bitte wähle deinen Namen'}
      </h2>
      {
        people.length === 0 && (
          <p class="text-gray-600 mt-2">
            Geh zu Einstellungen und füge Familienmitglieder hinzu.
          </p>
        )
      }
    </Card>

    {
      people.length > 0 && (
        <PersonGrid people={people} />
      )
    }
  </div>
</KioskLayout>
