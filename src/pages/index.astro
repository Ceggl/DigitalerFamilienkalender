---
// Home page / calendar overview
// Shows a family calendar view (initially empty for Phase 0)

import KioskLayout from '@/layouts/KioskLayout.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';

const today = new Date().toLocaleDateString('de-DE', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<KioskLayout title="Familienkalender">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main calendar area -->
    <div class="lg:col-span-2">
      <Card className="mb-6">
        <div class="text-center">
          <h2 class="text-2xl font-semibold text-gray-900 mb-2">Heute</h2>
          <p class="text-gray-600">{today}</p>
        </div>
      </Card>

      <!-- Calendar grid placeholder -->
      <Card>
        <div class="grid grid-cols-7 gap-2">
          {
            ['Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa', 'So'].map((day) => (
              <div class="text-center font-semibold text-sm text-gray-600 py-2">{day}</div>
            ))
          }
          {
            Array.from({ length: 35 }).map((_, i) => (
              <div class="aspect-square bg-gray-50 rounded-lg border border-gray-200 flex items-center justify-center text-gray-400 hover:bg-gray-100 cursor-pointer transition-colors">
                {i + 1}
              </div>
            ))
          }
        </div>
      </Card>
    </div>

    <!-- Sidebar -->
    <div class="space-y-4">
      <Card>
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Schnellzugriff</h3>
        <div class="space-y-3">
          <Button variant="primary" size="lg" className="w-full">
            👤 Anmelden
          </Button>
          <Button variant="secondary" size="lg" className="w-full">
            ➕ Termin hinzufügen
          </Button>
          <Button variant="ghost" size="lg" className="w-full">
            ⚙️ Einstellungen
          </Button>
        </div>
      </Card>

      <Card>
        <h3 class="text-lg font-semibold text-gray-900 mb-3">Info</h3>
        <p class="text-sm text-gray-600">
          Willkommen im Familienkalender! Der Plan ist verfügbar in <code className="bg-gray-100 px-2 py-1 rounded"
            >docs/plan.md</code
          >.
        </p>
      </Card>
    </div>
  </div>
</KioskLayout>
